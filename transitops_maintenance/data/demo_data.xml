<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Demo data for transitops_maintenance module.
            These records mirror the placeholder data from the React frontend
            so the Odoo backend feels consistent during development.

            NOTE: vehicle_id references (e.g., transitops_core.vehicle_bus_1042)
            must exist in transitops_core's demo data. Adjust the ref values
            once Juhi publishes her vehicle demo records.
        -->

        <!-- ══════════════════════════════════════════════════
             Maintenance Requests
             ══════════════════════════════════════════════════ -->
        <record id="transitops_maintenance.demo_maint_001" model="transitops.maintenance.request">
            <field name="name">MNT-0001</field>
            <field name="vehicle_id" ref="transitops_core.vehicle_bus_1042"/>
            <field name="maintenance_type">engine_overhaul</field>
            <field name="date_opened">2026-06-28</field>
            <field name="status">open</field>
            <field name="cost">18500.00</field>
            <field name="notes">Engine overheating reported during route BLR-MYS. Full overhaul scheduled.</field>
        </record>

        <record id="transitops_maintenance.demo_maint_002" model="transitops.maintenance.request">
            <field name="name">MNT-0002</field>
            <field name="vehicle_id" ref="transitops_core.vehicle_van_0217"/>
            <field name="maintenance_type">brake_pad</field>
            <field name="date_opened">2026-07-01</field>
            <field name="date_closed">2026-07-05</field>
            <field name="status">closed</field>
            <field name="cost">4200.00</field>
            <field name="notes">Front brake pads worn out. Replaced with OEM parts.</field>
        </record>

        <record id="transitops_maintenance.demo_maint_003" model="transitops.maintenance.request">
            <field name="name">MNT-0003</field>
            <field name="vehicle_id" ref="transitops_core.vehicle_trk_0883"/>
            <field name="maintenance_type">oil_change</field>
            <field name="date_opened">2026-07-10</field>
            <field name="status">open</field>
            <field name="cost">3200.00</field>
            <field name="notes">Routine 10,000 km service — oil change and filter replacement.</field>
        </record>

        <!-- ══════════════════════════════════════════════════
             Fuel Logs
             ══════════════════════════════════════════════════ -->
        <record id="transitops_maintenance.demo_fuel_001" model="transitops.fuel.log">
            <field name="vehicle_id" ref="transitops_core.vehicle_bus_1042"/>
            <field name="date">2026-07-08</field>
            <field name="liters">120.0</field>
            <field name="price_per_liter">80.0</field>
            <field name="odometer">45230.5</field>
            <field name="notes">Full tank fill at Hindustan Petroleum, Koramangala.</field>
        </record>

        <record id="transitops_maintenance.demo_fuel_002" model="transitops.fuel.log">
            <field name="vehicle_id" ref="transitops_core.vehicle_van_0217"/>
            <field name="date">2026-07-09</field>
            <field name="liters">45.0</field>
            <field name="price_per_liter">80.0</field>
            <field name="odometer">23100.0</field>
            <field name="notes">Partial fill before intra-city delivery run.</field>
        </record>

        <record id="transitops_maintenance.demo_fuel_003" model="transitops.fuel.log">
            <field name="vehicle_id" ref="transitops_core.vehicle_trk_0883"/>
            <field name="date">2026-07-10</field>
            <field name="liters">200.0</field>
            <field name="price_per_liter">80.0</field>
            <field name="odometer">89750.0</field>
            <field name="notes">Full diesel fill for long-haul trip BLR-HYD.</field>
        </record>

        <!-- ══════════════════════════════════════════════════
             Expense Logs
             ══════════════════════════════════════════════════ -->
        <record id="transitops_maintenance.demo_expense_001" model="transitops.expense.log">
            <field name="vehicle_id" ref="transitops_core.vehicle_bus_1042"/>
            <field name="date">2026-07-07</field>
            <field name="expense_type">toll</field>
            <field name="cost">1200.00</field>
            <field name="description">NICE Road toll — Hosur to Electronic City round trip.</field>
        </record>

        <record id="transitops_maintenance.demo_expense_002" model="transitops.expense.log">
            <field name="vehicle_id" ref="transitops_core.vehicle_van_0217"/>
            <field name="date">2026-07-08</field>
            <field name="expense_type">parking</field>
            <field name="cost">350.00</field>
            <field name="description">Full-day parking at Whitefield commercial hub.</field>
        </record>

        <record id="transitops_maintenance.demo_expense_003" model="transitops.expense.log">
            <field name="vehicle_id" ref="transitops_core.vehicle_trk_0883"/>
            <field name="date">2026-07-10</field>
            <field name="expense_type">driver_allowance</field>
            <field name="cost">2500.00</field>
            <field name="description">Driver daily allowance for 2-day BLR-HYD trip.</field>
        </record>

    </data>
</odoo>

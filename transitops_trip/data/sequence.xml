<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Auto-sequence for Trip references: TRP-0001, TRP-0002, … -->
        <record id="transitops_trip.seq_trip" model="ir.sequence">
            <field name="name">TransitOps Trip Sequence</field>
            <field name="code">transitops.trip</field>
            <field name="prefix">TRP-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
